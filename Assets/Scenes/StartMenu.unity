  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 63f355cdc5ce7eb48af54d0efd32baa2, type: 3}
  m_Name: 
  m_EditorClassIdentifier: Assembly-CSharp::StartMenuController
  _pageContents:
  - 'WELCOME


    Look around to find your weapon on the table.

    Pick it up
    with the Grab button.'
  - "CONTROLS\n\nTrigger \u2014 Shoot\nGrab \u2014 Pick up items\nA \u2014 Reseat
    barrel slide (after empty)\nB \u2014 Eject magazine\nX \u2014 Pause / Resume\nYou
    can locate a HUD displaying all information on left hand wrist"
  - "RELOADING\n\nLook down at your hip:\n\u2022 Two holster rings hold weapons\n\u2022
    Reach between them for a fresh magazine (AMMO pouch)\n\nEject empty mag with
    B,\ngrab a new one,\nbring it to the gun."
  - 'READY


    Fire one shot at the table to unlock the START button.

    Then
    press START to begin.'
  _pageText: {fileID: 1405750024}
  _pageCounterText: {fileID: 1952228056}
  _startButtonAnchor: {fileID: 233739817}
  _quitButtonAnchor: {fileID: 220022419}
  _nextButtonAnchor: {fileID: 183076623}
  _prevButtonAnchor: {fileID: 995418712}
  _startReadyText: START
  _startLockedText: LOCKED
  _gameSceneName: FinalQuestScene_JerryPlayground
  _labelLocalOffset: {x: 0, y: 0.2, z: 0}
  _labelWorldHeight: 0.15
  _labelFontSize: 64
  _labelReadyColor: {r: 1, g: 0.95, b: 0.4, a: 1}
  _labelLockedColor: {r: 0.55, g: 0.55, b: 0.55, a: 1}
  _labelBgColor: {r: 0.05, g: 0.05, b: 0.05, a: 1}
